    <!-- FLOATING CTA (MOBILE) -->
    <div class="floating-cta" id="floatingCta">
        <a href="#diagnostico" class="btn btn-primary" aria-label="Solicitar diagnostico">Solicitar Diagnostico &rarr;</a>
    </div>

    <script>
        (function() {
            'use strict';

            // ============================================
            // PROGRESS BAR
            // ============================================
            var progressBar = document.getElementById('progressBar');
            function updateProgress() {
                var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
                var docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                var progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
                progressBar.style.width = progress + '%';
            }

            // ============================================
            // NAVBAR SCROLL
            // ============================================
            var navbar = document.getElementById('navbar');
            function handleNavbarScroll() {
                if (window.pageYOffset > 60) {
                    navbar.classList.add('scrolled');
                } else {
                    navbar.classList.remove('scrolled');
                }
            }

            // ============================================
            // HAMBURGER MENU
            // ============================================
            var hamburger = document.getElementById('hamburger');
            var mobileMenu = document.getElementById('mobileMenu');
            var mobileOverlay = document.getElementById('mobileOverlay');

            function toggleMenu() {
                var isActive = hamburger.classList.toggle('active');
                mobileMenu.classList.toggle('active');
                mobileOverlay.classList.toggle('active');
                hamburger.setAttribute('aria-expanded', isActive);
                document.body.style.overflow = isActive ? 'hidden' : '';
            }

            function closeMenu() {
                hamburger.classList.remove('active');
                mobileMenu.classList.remove('active');
                mobileOverlay.classList.remove('active');
                hamburger.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
            }

            hamburger.addEventListener('click', toggleMenu);
            mobileOverlay.addEventListener('click', closeMenu);

            // Close menu when clicking links
            var mobileLinks = mobileMenu.querySelectorAll('a');
            mobileLinks.forEach(function(link) {
                link.addEventListener('click', closeMenu);
            });

            // ============================================
            // SMOOTH SCROLL
            // ============================================
            document.querySelectorAll('a[href^="#"]').forEach(function(anchor) {
                anchor.addEventListener('click', function(e) {
                    var targetId = this.getAttribute('href');
                    if (targetId === '#') return;
                    var target = document.querySelector(targetId);
                    if (target) {
                        e.preventDefault();
                        var offset = navbar.offsetHeight + 16;
                        var targetPosition = target.getBoundingClientRect().top + window.pageYOffset - offset;
                        window.scrollTo({
                            top: targetPosition,
                            behavior: 'smooth'
                        });
                    }
                });
            });

            // ============================================
            // PHONE MASK (00) 00000-0000
            // ============================================
            function applyPhoneMask(input) {
                input.addEventListener('input', function(e) {
                    var value = e.target.value.replace(/\D/g, '');
                    if (value.length > 11) value = value.slice(0, 11);

                    var formatted = '';
                    if (value.length > 0) {
                        formatted = '(' + value.slice(0, 2);
                    }
                    if (value.length > 2) {
                        formatted += ') ' + value.slice(2, 7);
                    }
                    if (value.length > 7) {
                        formatted += '-' + value.slice(7, 11);
                    }

                    e.target.value = formatted;
                });
            }

            document.querySelectorAll('.phone-mask').forEach(applyPhoneMask);

            // ============================================
            // SCROLL REVEAL (IntersectionObserver)
            // ============================================
            var revealElements = document.querySelectorAll('[data-reveal]');
            var revealObserver = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('revealed');
                        revealObserver.unobserve(entry.target);
                    }
                });
            }, {
                threshold: 0.1,
                rootMargin: '0px 0px -40px 0px'
            });

            revealElements.forEach(function(el) {
                revealObserver.observe(el);
            });

            // ============================================
            // COUNTER ANIMATION (easeOutQuart)
            // ============================================
            function easeOutQuart(t) {
                return 1 - Math.pow(1 - t, 4);
            }

            function animateCounter(element) {
                var target = parseInt(element.getAttribute('data-counter'));
                var prefix = element.getAttribute('data-prefix') || '';
                var suffix = element.getAttribute('data-suffix') || '';
                var duration = 2000;
                var start = null;

                function step(timestamp) {
                    if (!start) start = timestamp;
                    var progress = Math.min((timestamp - start) / duration, 1);
                    var easedProgress = easeOutQuart(progress);
                    var current = Math.floor(easedProgress * target);
                    element.textContent = prefix + current.toLocaleString('pt-BR') + suffix;
                    if (progress < 1) {
                        requestAnimationFrame(step);
                    } else {
                        element.textContent = prefix + target.toLocaleString('pt-BR') + suffix;
                    }
                }

                requestAnimationFrame(step);
            }

            var counterElements = document.querySelectorAll('[data-counter]');
            var counterObserver = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        animateCounter(entry.target);
                        counterObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.3 });

            counterElements.forEach(function(el) {
                counterObserver.observe(el);
            });

            // ============================================
            // FAQ ACCORDION
            // ============================================
            document.querySelectorAll('.faq-question').forEach(function(question) {
                question.addEventListener('click', function() {
                    var item = this.parentElement;
                    var answer = item.querySelector('.faq-answer');
                    var inner = answer.querySelector('.faq-answer-inner');
                    var isActive = item.classList.contains('active');

                    // Close all
                    document.querySelectorAll('.faq-item.active').forEach(function(activeItem) {
                        activeItem.classList.remove('active');
                        activeItem.querySelector('.faq-answer').style.maxHeight = '0';
                        activeItem.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
                    });

                    // Open clicked if not already active
                    if (!isActive) {
                        item.classList.add('active');
                        answer.style.maxHeight = inner.scrollHeight + 'px';
                        this.setAttribute('aria-expanded', 'true');
                    }
                });

                question.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        this.click();
                    }
                });
            });

            // ============================================
            // FORM VALIDATION & SUBMISSION
            // ============================================
            function validateEmail(email) {
                return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
            }

            function validatePhone(phone) {
                var digits = phone.replace(/\D/g, '');
                return digits.length >= 10 && digits.length <= 11;
            }

            function showFieldError(field) {
                field.classList.add('error');
                var msg = field.parentElement.querySelector('.error-msg');
                if (msg) msg.classList.add('visible');
            }

            function clearFieldError(field) {
                field.classList.remove('error');
                var msg = field.parentElement.querySelector('.error-msg');
                if (msg) msg.classList.remove('visible');
            }

            // Live validation on blur
            document.querySelectorAll('form input, form select, form textarea').forEach(function(field) {
                field.addEventListener('blur', function() {
                    if (this.hasAttribute('required') && !this.value.trim()) {
                        showFieldError(this);
                    } else if (this.type === 'email' && this.value && !validateEmail(this.value)) {
                        showFieldError(this);
                    } else if (this.classList.contains('phone-mask') && this.value && !validatePhone(this.value)) {
                        showFieldError(this);
                    } else {
                        clearFieldError(this);
                    }
                });

                field.addEventListener('input', function() {
                    if (this.classList.contains('error')) {
                        clearFieldError(this);
                    }
                });
            });

            // Hero form
            document.getElementById('heroForm').addEventListener('submit', function(e) {
                e.preventDefault();
                var valid = true;
                var form = this;

                var nome = form.querySelector('#heroNome');
                var empresa = form.querySelector('#heroEmpresa');
                var whatsapp = form.querySelector('#heroWhatsapp');

                if (!nome.value.trim()) { showFieldError(nome); valid = false; } else { clearFieldError(nome); }
                if (!empresa.value.trim()) { showFieldError(empresa); valid = false; } else { clearFieldError(empresa); }
                if (!whatsapp.value.trim() || !validatePhone(whatsapp.value)) { showFieldError(whatsapp); valid = false; } else { clearFieldError(whatsapp); }

                if (!valid) return;

                // TODO: Integrate webhook here (n8n/Make/Zapier)
                // Example: fetch('YOUR_WEBHOOK_URL', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(formData) })

                var formData = {
                    nome: nome.value,
                    empresa: empresa.value,
                    whatsapp: whatsapp.value,
                    segmento: form.querySelector('#heroSegmento').value,
                    source: 'hero_form'
                };
                console.log('Hero form data:', formData);

                document.getElementById('heroFormContent').style.display = 'none';
                document.getElementById('heroFormSuccess').classList.add('visible');
            });

            // Diagnosis form
            document.getElementById('diagForm').addEventListener('submit', function(e) {
                e.preventDefault();
                var valid = true;
                var form = this;

                var nome = form.querySelector('#diagNome');
                var email = form.querySelector('#diagEmail');
                var tel = form.querySelector('#diagTel');
                var empresa = form.querySelector('#diagEmpresa');

                if (!nome.value.trim()) { showFieldError(nome); valid = false; } else { clearFieldError(nome); }
                if (!email.value.trim() || !validateEmail(email.value)) { showFieldError(email); valid = false; } else { clearFieldError(email); }
                if (!tel.value.trim() || !validatePhone(tel.value)) { showFieldError(tel); valid = false; } else { clearFieldError(tel); }
                if (!empresa.value.trim()) { showFieldError(empresa); valid = false; } else { clearFieldError(empresa); }

                if (!valid) return;

                // TODO: Integrate webhook here (n8n/Make/Zapier)
                // Example: fetch('YOUR_WEBHOOK_URL', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(formData) })

                var formData = {
                    nome: nome.value,
                    email: email.value,
                    telefone: tel.value,
                    empresa: empresa.value,
                    segmento: form.querySelector('#diagSegmento').value,
                    source: 'diagnosis_form'
                };
                console.log('Diagnosis form data:', formData);

                document.getElementById('diagFormContent').style.display = 'none';
                document.getElementById('diagFormSuccess').classList.add('visible');
            });

            // Main form
            document.getElementById('mainForm').addEventListener('submit', function(e) {
                e.preventDefault();
                var valid = true;
                var form = this;

                var nome = form.querySelector('#mainNome');
                var empresa = form.querySelector('#mainEmpresa');
                var email = form.querySelector('#mainEmail');
                var tel = form.querySelector('#mainTel');
                var privacy = form.querySelector('#mainPrivacy');
                var privacyError = document.getElementById('privacyError');

                if (!nome.value.trim()) { showFieldError(nome); valid = false; } else { clearFieldError(nome); }
                if (!empresa.value.trim()) { showFieldError(empresa); valid = false; } else { clearFieldError(empresa); }
                if (!email.value.trim() || !validateEmail(email.value)) { showFieldError(email); valid = false; } else { clearFieldError(email); }
                if (!tel.value.trim() || !validatePhone(tel.value)) { showFieldError(tel); valid = false; } else { clearFieldError(tel); }

                if (!privacy.checked) {
                    privacyError.classList.add('visible');
                    valid = false;
                } else {
                    privacyError.classList.remove('visible');
                }

                if (!valid) return;

                // TODO: Integrate webhook here (n8n/Make/Zapier)
                // Example: fetch('YOUR_WEBHOOK_URL', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(formData) })

                var formData = {
                    nome: nome.value,
                    empresa: empresa.value,
                    email: email.value,
                    telefone: tel.value,
                    segmento: form.querySelector('#mainSegmento').value,
                    porte: form.querySelector('#mainPorte').value,
                    mensagem: form.querySelector('#mainMensagem').value,
                    source: 'main_form'
                };
                console.log('Main form data:', formData);

                document.getElementById('mainFormContent').style.display = 'none';
                document.getElementById('mainFormSuccess').classList.add('visible');
            });

            // ============================================
            // FLOATING CTA VISIBILITY
            // ============================================
            var floatingCta = document.getElementById('floatingCta');
            var contatoSection = document.getElementById('contato');

            var floatingObserver = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        floatingCta.classList.add('hidden');
                    } else {
                        floatingCta.classList.remove('hidden');
                    }
                });
            }, { threshold: 0.1 });

            if (contatoSection) {
                floatingObserver.observe(contatoSection);
            }

            // Also observe diagnostico section
            var diagSection = document.getElementById('diagnostico');
            if (diagSection) {
                var diagObserver = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting) {
                            floatingCta.classList.add('hidden');
                        }
                    });
                }, { threshold: 0.1 });
                diagObserver.observe(diagSection);
            }

            // ============================================
            // DASHBOARD CHART ANIMATION
            // ============================================
            var chartLine = document.getElementById('chartLine');
            var dashboardMock = document.getElementById('dashboardMock');
            var channelBars = document.querySelectorAll('.channel-bar-fill');

            var dashboardObserver = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        // Animate line chart
                        if (chartLine) {
                            chartLine.classList.add('animated');
                        }
                        // Animate channel bars
                        channelBars.forEach(function(bar) {
                            var targetWidth = bar.getAttribute('data-width');
                            setTimeout(function() {
                                bar.style.width = targetWidth;
                                bar.classList.add('animated');
                            }, 400);
                        });
                        dashboardObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.2 });

            if (dashboardMock) {
                dashboardObserver.observe(dashboardMock);
            }

            // ============================================
            // SCROLL EVENT LISTENER (throttled)
            // ============================================
            var ticking = false;
            window.addEventListener('scroll', function() {
                if (!ticking) {
                    requestAnimationFrame(function() {
                        updateProgress();
                        handleNavbarScroll();
                        ticking = false;
                    });
                    ticking = true;
                }
            });

            // Initial calls
            updateProgress();
            handleNavbarScroll();
        })();
    </script>
</body>
</html>
