<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Media.K | Crescimento Rastreavel no Mercado 50+ | Silver Economy</title>
    <meta name="description" content="A Media.K ajuda marcas a gerar demanda qualificada no mercado 50+ com midia, CRM, BI, tracking e Metodo Estrela do Norte. Solicite diagnostico gratuito.">
    <meta property="og:title" content="Media.K | Especialistas em Crescimento no Mercado 50+">
    <meta property="og:description" content="Midia, CRM, BI e tracking para gerar demanda qualificada no mercado 50+. Metodo proprio, +100 marcas impulsionadas e parceiros Google, Meta e TikTok.">
    <meta property="og:image" content="https://www.mediak.com.br/icon.png">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.mediak.com.br">
    <meta name="theme-color" content="#0574dd">
    <link rel="icon" href="https://www.mediak.com.br/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* ============================================
           CSS RESET & BASE
           ============================================ */
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --blue: #0574dd;
            --cyan: #02d3f1;
            --pink: #fd3b66;
            --yellow: #ffd400;
            --dark: #0f172a;
            --body: #334155;
            --muted: #64748b;
            --border: #e2e8f0;
            --bg: #ffffff;
            --bg-alt: #f8faff;
            --radius-card: 14px;
            --radius-btn: 8px;
            --shadow-card: 0 1px 3px rgba(0,0,0,0.05), 0 4px 16px rgba(0,0,0,0.08);
            --shadow-card-hover: 0 2px 8px rgba(0,0,0,0.08), 0 8px 32px rgba(0,0,0,0.12);
            --transition: all 0.2s ease;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;
            color: var(--body);
            background: var(--bg);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            overflow-x: hidden;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
        }

        a {
            text-decoration: none;
            color: inherit;
            transition: var(--transition);
        }

        ul, ol {
            list-style: none;
        }

        input, select, textarea, button {
            font-family: inherit;
            font-size: inherit;
            outline: none;
            border: none;
            background: none;
        }

        /* ============================================
           PROGRESS BAR
           ============================================ */
        .progress-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 3px;
            width: 0%;
            background: linear-gradient(90deg, var(--blue), var(--cyan));
            z-index: 10001;
            transition: width 0.1s linear;
        }

        /* ============================================
           CONTAINER
           ============================================ */
        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        @media (min-width: 768px) {
            .container {
                padding: 0 32px;
            }
        }

        @media (min-width: 1024px) {
            .container {
                padding: 0 40px;
            }
        }

        /* ============================================
           TYPOGRAPHY
           ============================================ */
        h1, h2, h3, h4, h5, h6 {
            color: var(--dark);
            line-height: 1.2;
            font-weight: 700;
        }

        h1 { font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 800; }
        h2 { font-size: clamp(1.75rem, 4vw, 2.5rem); }
        h3 { font-size: clamp(1.25rem, 3vw, 1.5rem); }
        h4 { font-size: 1.125rem; }

        .section-label {
            display: inline-block;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--blue);
            margin-bottom: 12px;
        }

        .section-title {
            margin-bottom: 16px;
        }

        .section-subtitle {
            font-size: 1.1rem;
            color: var(--muted);
            max-width: 640px;
            line-height: 1.7;
        }

        .section-header {
            text-align: center;
            margin-bottom: 56px;
        }

        .section-header .section-subtitle {
            margin: 0 auto;
        }

        /* ============================================
           BUTTONS
           ============================================ */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 50px;
            padding: 12px 28px;
            font-weight: 600;
            font-size: 0.95rem;
            border-radius: var(--radius-btn);
            cursor: pointer;
            transition: var(--transition);
            white-space: nowrap;
        }

        .btn:focus-visible {
            outline: 2px solid var(--blue);
            outline-offset: 2px;
        }

        .btn-primary {
            background: var(--blue);
            color: #fff;
        }

        .btn-primary:hover {
            background: #0460b8;
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(5, 116, 221, 0.35);
        }

        .btn-outline {
            background: transparent;
            color: var(--blue);
            border: 2px solid var(--blue);
        }

        .btn-outline:hover {
            background: var(--blue);
            color: #fff;
            transform: translateY(-1px);
        }

        .btn-dark {
            background: var(--dark);
            color: #fff;
        }

        .btn-dark:hover {
            background: #1e293b;
            transform: translateY(-1px);
        }

        .btn-white {
            background: #fff;
            color: var(--blue);
            font-weight: 600;
        }

        .btn-white:hover {
            background: #f0f7ff;
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(0,0,0,0.15);
        }

        /* ============================================
           SECTION SPACING
           ============================================ */
        .section {
            padding: 80px 0;
        }

        @media (min-width: 768px) {
            .section {
                padding: 100px 0;
            }
        }

        @media (min-width: 1024px) {
            .section {
                padding: 120px 0;
            }
        }

        .section-dark {
            background: var(--dark);
        }

        .section-dark h2,
        .section-dark h3,
        .section-dark h4,
        .section-dark .section-label {
            color: #fff;
        }

        .section-dark .section-subtitle,
        .section-dark p {
            color: #94a3b8;
        }

        .section-alt {
            background: var(--bg-alt);
        }

        /* ============================================
           CARDS
           ============================================ */
        .card {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-card);
            box-shadow: var(--shadow-card);
            padding: 32px;
            transition: var(--transition);
        }

        .card:hover {
            border-color: var(--blue);
            box-shadow: var(--shadow-card-hover);
        }

        /* ============================================
           FORM STYLES
           ============================================ */
        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--dark);
            margin-bottom: 6px;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            min-height: 48px;
            padding: 12px 16px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-btn);
            color: var(--dark);
            font-size: 0.95rem;
            transition: var(--transition);
        }

        .form-group textarea {
            min-height: 100px;
            resize: vertical;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 3px rgba(5, 116, 221, 0.1);
        }

        .form-group input.error,
        .form-group select.error,
        .form-group textarea.error {
            border-color: var(--pink);
        }

        .form-group .error-msg {
            color: var(--pink);
            font-size: 0.8rem;
            margin-top: 4px;
            display: none;
        }

        .form-group .error-msg.visible {
            display: block;
        }

        .form-dark input,
        .form-dark select,
        .form-dark textarea {
            background: rgba(255,255,255,0.06);
            border-color: rgba(255,255,255,0.12);
            color: #fff;
        }

        .form-dark input::placeholder,
        .form-dark textarea::placeholder {
            color: #64748b;
        }

        .form-dark input:focus,
        .form-dark select:focus,
        .form-dark textarea:focus {
            border-color: var(--cyan);
            box-shadow: 0 0 0 3px rgba(2, 211, 241, 0.1);
        }

        .form-dark label {
            color: #e2e8f0;
        }

        .form-dark select option {
            background: var(--dark);
            color: #fff;
        }

        /* ============================================
           SCROLL REVEAL
           ============================================ */
        [data-reveal] {
            opacity: 0;
            transform: translateY(24px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        [data-reveal].revealed {
            opacity: 1;
            transform: translateY(0);
        }

        /* ============================================
           NAVBAR
           ============================================ */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 10000;
            padding: 16px 0;
            transition: all 0.3s ease;
        }

        .navbar.scrolled {
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            box-shadow: 0 1px 8px rgba(0,0,0,0.06);
            padding: 10px 0;
        }

        .navbar .container {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .navbar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .navbar-logo img {
            height: 36px;
            width: auto;
        }

        .navbar-logo span {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--dark);
        }

        .navbar-links {
            display: none;
            align-items: center;
            gap: 32px;
        }

        @media (min-width: 1024px) {
            .navbar-links {
                display: flex;
            }
        }

        .navbar-links a {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--body);
        }

        .navbar-links a:hover {
            color: var(--blue);
        }

        .navbar-cta {
            display: none;
        }

        @media (min-width: 1024px) {
            .navbar-cta {
                display: inline-flex;
            }
        }

        /* Hamburger */
        .hamburger {
            display: flex;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 8px;
            z-index: 10002;
        }

        @media (min-width: 1024px) {
            .hamburger {
                display: none;
            }
        }

        .hamburger span {
            width: 24px;
            height: 2px;
            background: var(--dark);
            transition: var(--transition);
            border-radius: 2px;
        }

        .hamburger.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }

        .hamburger.active span:nth-child(2) {
            opacity: 0;
        }

        .hamburger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -5px);
        }

        /* Mobile menu */
        .mobile-menu {
            position: fixed;
            top: 0;
            right: -100%;
            width: 80%;
            max-width: 360px;
            height: 100vh;
            background: #fff;
            z-index: 10001;
            padding: 80px 32px 32px;
            transition: right 0.3s ease;
            box-shadow: -4px 0 24px rgba(0,0,0,0.1);
        }

        .mobile-menu.active {
            right: 0;
        }

        .mobile-menu a {
            display: block;
            padding: 16px 0;
            font-size: 1.1rem;
            font-weight: 500;
            color: var(--dark);
            border-bottom: 1px solid var(--border);
        }

        .mobile-menu a:hover {
            color: var(--blue);
        }

        .mobile-menu .btn {
            width: 100%;
            margin-top: 24px;
        }

        .mobile-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.4);
            z-index: 10000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .mobile-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

        /* ============================================
           HERO
           ============================================ */
        .hero {
            padding: 140px 0 80px;
            background: var(--bg);
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -200px;
            right: -200px;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(5,116,221,0.06) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero::after {
            content: '';
            position: absolute;
            bottom: -150px;
            left: -150px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(2,211,241,0.05) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero .container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 48px;
            align-items: center;
        }

        @media (min-width: 1024px) {
            .hero .container {
                grid-template-columns: 1.1fr 0.9fr;
                gap: 64px;
            }
        }

        .hero-copy {
            position: relative;
            z-index: 2;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(5,116,221,0.06);
            border: 1px solid rgba(5,116,221,0.12);
            border-radius: 100px;
            padding: 6px 16px;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--blue);
            margin-bottom: 24px;
        }

        .hero-badge::before {
            content: '';
            width: 8px;
            height: 8px;
            background: var(--blue);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        .hero h1 {
            margin-bottom: 20px;
            color: var(--dark);
        }

        .hero h1 .highlight {
            background: linear-gradient(135deg, var(--blue), var(--cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-sub {
            font-size: 1.1rem;
            color: var(--muted);
            line-height: 1.8;
            margin-bottom: 32px;
            max-width: 520px;
        }

        .hero-ctas {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 48px;
        }

        .hero-proof {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        @media (min-width: 480px) {
            .hero-proof {
                grid-template-columns: repeat(4, 1fr);
            }
        }

        .hero-proof-item {
            text-align: left;
        }

        .hero-proof-number {
            font-size: 1.75rem;
            font-weight: 800;
            color: var(--dark);
            line-height: 1;
            margin-bottom: 4px;
        }

        .hero-proof-label {
            font-size: 0.8rem;
            color: var(--muted);
            font-weight: 500;
        }

        /* Hero Form Card */
        .hero-form-card {
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-card);
            box-shadow: 0 4px 24px rgba(0,0,0,0.08), 0 12px 48px rgba(0,0,0,0.06);
            padding: 36px;
            position: relative;
            z-index: 2;
        }

        .hero-form-card h3 {
            font-size: 1.3rem;
            margin-bottom: 8px;
        }

        .hero-form-card .form-subtitle {
            font-size: 0.875rem;
            color: var(--muted);
            margin-bottom: 24px;
            line-height: 1.6;
        }

        .hero-form-card .btn {
            width: 100%;
        }

        .form-trust {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 16px;
            font-size: 0.78rem;
            color: var(--muted);
        }

        .form-trust svg {
            flex-shrink: 0;
        }

        .form-success {
            display: none;
            text-align: center;
            padding: 24px 0;
        }

        .form-success.visible {
            display: block;
        }

        .form-success .success-icon {
            width: 64px;
            height: 64px;
            background: rgba(16, 185, 129, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            font-size: 1.75rem;
            animation: scaleIn 0.4s ease;
        }

        @keyframes scaleIn {
            0% { transform: scale(0); }
            60% { transform: scale(1.15); }
            100% { transform: scale(1); }
        }

        .form-success h4 {
            color: #10b981;
            margin-bottom: 8px;
        }

        .form-success p {
            color: var(--muted);
            font-size: 0.9rem;
        }

        /* ============================================
           TRUST BAR
           ============================================ */
        .trust-bar {
            background: var(--dark);
            padding: 28px 0;
        }

        .trust-bar .container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            gap: 24px 40px;
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #94a3b8;
            font-size: 0.85rem;
            font-weight: 500;
            white-space: nowrap;
        }

        .trust-item .trust-icon {
            width: 32px;
            height: 32px;
            background: rgba(255,255,255,0.06);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .trust-item strong {
            color: #fff;
        }

        /* ============================================
           CLIENTS
           ============================================ */
        .clients-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 48px;
        }

        @media (min-width: 768px) {
            .clients-grid {
                grid-template-columns: 1fr 1fr;
                gap: 64px;
            }
        }

        .clients-subsection h3 {
            font-size: 1.1rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .clients-subsection h3::before {
            content: '';
            width: 4px;
            height: 20px;
            background: var(--blue);
            border-radius: 2px;
        }

        .chips {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 100px;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--dark);
            transition: var(--transition);
        }

        .chip:hover {
            border-color: var(--blue);
            background: rgba(5,116,221,0.03);
        }

        .chip-icon {
            width: 24px;
            height: 24px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
            color: #fff;
        }

        .partner-chip {
            padding: 10px 18px;
            background: rgba(5,116,221,0.04);
            border-color: rgba(5,116,221,0.12);
        }

        .partner-chip svg {
            width: 18px;
            height: 18px;
        }

        /* ============================================
           CASES
           ============================================ */
        .cases-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }

        @media (min-width: 768px) {
            .cases-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .case-card {
            padding: 36px;
        }

        .case-card .case-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 20px;
        }

        .case-brand-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            font-weight: 700;
            color: #fff;
        }

        .case-brand h4 {
            font-size: 1rem;
        }

        .case-brand span {
            font-size: 0.8rem;
            color: var(--muted);
        }

        .case-step {
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }

        .case-step:last-child {
            border-bottom: none;
        }

        .case-step-label {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }

        .case-step-label.desafio { color: var(--pink); }
        .case-step-label.solucao { color: var(--blue); }
        .case-step-label.resultado { color: #10b981; }

        .case-step p {
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .case-result-highlight {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(16,185,129,0.08);
            color: #10b981;
            font-weight: 600;
            font-size: 0.85rem;
            padding: 6px 14px;
            border-radius: 6px;
            margin-top: 8px;
        }

        /* ============================================
           METODO
           ============================================ */
        .metodo-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        @media (min-width: 480px) {
            .metodo-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .metodo-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .metodo-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius-card);
            padding: 32px;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .metodo-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--blue), var(--cyan));
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .metodo-card:hover {
            background: rgba(255,255,255,0.06);
            border-color: rgba(255,255,255,0.12);
        }

        .metodo-card:hover::before {
            opacity: 1;
        }

        .metodo-step-num {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--cyan);
            letter-spacing: 2px;
            margin-bottom: 16px;
        }

        .metodo-card h4 {
            font-size: 1.1rem;
            color: #fff;
            margin-bottom: 10px;
        }

        .metodo-card p {
            font-size: 0.875rem;
            color: #94a3b8;
            line-height: 1.7;
        }

        /* ============================================
           INTELLIGENCE
           ============================================ */
        .intel-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        @media (min-width: 480px) {
            .intel-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .intel-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .intel-card {
            padding: 28px;
        }

        .intel-card .intel-stat {
            font-size: 2rem;
            font-weight: 800;
            color: var(--blue);
            margin-bottom: 8px;
            line-height: 1;
        }

        .intel-card h4 {
            font-size: 1rem;
            margin-bottom: 8px;
        }

        .intel-card p {
            font-size: 0.85rem;
            color: var(--muted);
            line-height: 1.6;
        }

        /* ============================================
           DASHBOARD MOCKUP
           ============================================ */
        .dashboard-section {
            padding: 100px 0;
            background: var(--bg-alt);
        }

        .dashboard-mock {
            background: #1e293b;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.08);
            overflow: hidden;
            box-shadow: 0 8px 48px rgba(0,0,0,0.2);
            max-width: 900px;
            margin: 0 auto;
        }

        .dashboard-chrome {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 14px 20px;
            background: rgba(0,0,0,0.2);
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .chrome-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }

        .chrome-dot.red { background: #ef4444; }
        .chrome-dot.yellow { background: #fbbf24; }
        .chrome-dot.green { background: #22c55e; }

        .chrome-url {
            margin-left: 12px;
            background: rgba(255,255,255,0.06);
            border-radius: 6px;
            padding: 6px 16px;
            font-size: 0.75rem;
            color: #64748b;
            flex: 1;
            max-width: 300px;
        }

        .dashboard-content {
            padding: 24px;
        }

        .dashboard-kpis {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .kpi-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 10px;
            padding: 20px;
        }

        .kpi-label {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #64748b;
            margin-bottom: 8px;
        }

        .kpi-value {
            font-size: 1.5rem;
            font-weight: 800;
            color: #fff;
        }

        @media (max-width: 480px) {
            .kpi-value {
                font-size: 1.1rem;
            }
        }

        .kpi-change {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.75rem;
            font-weight: 600;
            color: #10b981;
            margin-top: 4px;
        }

        .dashboard-chart {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 24px;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .chart-title {
            font-size: 0.8rem;
            font-weight: 600;
            color: #94a3b8;
        }

        .chart-period {
            font-size: 0.7rem;
            color: #64748b;
            background: rgba(255,255,255,0.04);
            padding: 4px 10px;
            border-radius: 4px;
        }

        .dashboard-chart svg {
            width: 100%;
            height: auto;
        }

        .chart-line {
            stroke-dasharray: 800;
            stroke-dashoffset: 800;
            transition: stroke-dashoffset 2s ease;
        }

        .chart-line.animated {
            stroke-dashoffset: 0;
        }

        .dashboard-channels {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .channel-bar-item {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .channel-bar-label {
            font-size: 0.8rem;
            font-weight: 500;
            color: #94a3b8;
            min-width: 100px;
        }

        .channel-bar-track {
            flex: 1;
            height: 8px;
            background: rgba(255,255,255,0.04);
            border-radius: 4px;
            overflow: hidden;
        }

        .channel-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 1.2s ease;
            width: 0;
        }

        .channel-bar-fill.meta { background: linear-gradient(90deg, var(--blue), #0ea5e9); }
        .channel-bar-fill.google { background: linear-gradient(90deg, #f59e0b, #eab308); }
        .channel-bar-fill.taboola { background: linear-gradient(90deg, var(--cyan), #06b6d4); }

        .channel-bar-pct {
            font-size: 0.8rem;
            font-weight: 600;
            color: #fff;
            min-width: 36px;
            text-align: right;
        }

        /* ============================================
           COMPARISON
           ============================================ */
        .comparison-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }

        @media (min-width: 768px) {
            .comparison-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .comparison-col {
            border-radius: var(--radius-card);
            padding: 40px;
        }

        .comparison-col.traditional {
            background: #f8fafc;
            border: 1px solid var(--border);
        }

        .comparison-col.mediak {
            background: var(--dark);
            border: 1px solid rgba(5,116,221,0.3);
            position: relative;
            overflow: hidden;
        }

        .comparison-col.mediak::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--blue), var(--cyan));
        }

        .comparison-col h3 {
            font-size: 1.15rem;
            margin-bottom: 28px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .comparison-col.mediak h3 {
            color: #fff;
        }

        .comparison-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .comparison-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .comparison-item .icon-x {
            flex-shrink: 0;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: rgba(253,59,102,0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 2px;
        }

        .comparison-item .icon-check {
            flex-shrink: 0;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: rgba(16,185,129,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 2px;
        }

        .comparison-col.mediak .comparison-item {
            color: #cbd5e1;
        }

        /* ============================================
           SILVER ECONOMY NUMBERS
           ============================================ */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        @media (min-width: 480px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .stats-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .stat-card {
            text-align: center;
            padding: 36px 24px;
        }

        .stat-card .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--blue), var(--cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            line-height: 1;
            margin-bottom: 8px;
        }

        .stat-card h4 {
            font-size: 0.95rem;
            margin-bottom: 6px;
        }

        .stat-card p {
            font-size: 0.8rem;
            color: var(--muted);
        }

        .stat-source {
            font-size: 0.7rem;
            color: var(--muted);
            opacity: 0.7;
            margin-top: 8px;
        }

        /* ============================================
           URGENCY
           ============================================ */
        .urgency-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        @media (min-width: 768px) {
            .urgency-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .urgency-card {
            padding: 36px;
            border-left: 3px solid var(--blue);
        }

        .urgency-card .urgency-num {
            font-size: 3rem;
            font-weight: 800;
            color: rgba(5,116,221,0.1);
            line-height: 1;
            margin-bottom: 12px;
        }

        .urgency-card h4 {
            margin-bottom: 8px;
        }

        .urgency-card p {
            font-size: 0.9rem;
            color: var(--muted);
            line-height: 1.7;
        }

        /* ============================================
           CHANNELS
           ============================================ */
        .channels-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        @media (min-width: 480px) {
            .channels-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .channels-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .channel-card {
            padding: 32px;
        }

        .channel-card .channel-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: rgba(5,116,221,0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
        }

        .channel-card h4 {
            margin-bottom: 8px;
        }

        .channel-card p {
            font-size: 0.875rem;
            color: var(--muted);
            line-height: 1.7;
        }

        /* ============================================
           DIFFERENTIALS
           ============================================ */
        .diff-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        @media (min-width: 480px) {
            .diff-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .diff-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .diff-card {
            padding: 32px;
        }

        .diff-card .diff-icon {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 16px;
            font-size: 1.3rem;
        }

        .diff-card h4 {
            margin-bottom: 8px;
        }

        .diff-card p {
            font-size: 0.875rem;
            color: var(--muted);
            line-height: 1.7;
        }

        /* ============================================
           LEADERSHIP
           ============================================ */
        .leadership-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 24px;
        }

        @media (min-width: 768px) {
            .leadership-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        .leader-card {
            text-align: center;
            padding: 40px 32px;
        }

        .leader-card .leader-photo {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            object-fit: cover;
            margin: 0 auto 20px;
            border: 3px solid var(--border);
        }

        .leader-card .leader-initials {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--blue), var(--cyan));
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
        }

        .leader-card h4 {
            margin-bottom: 4px;
        }

        .leader-card .leader-role {
            font-size: 0.85rem;
            color: var(--blue);
            font-weight: 500;
            margin-bottom: 12px;
        }

        .leader-card p {
            font-size: 0.85rem;
            color: var(--muted);
            line-height: 1.7;
        }

        /* ============================================
           DIAGNOSIS (DARK)
           ============================================ */
        .diagnosis-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 48px;
        }

        @media (min-width: 768px) {
            .diagnosis-grid {
                grid-template-columns: 1fr 1fr;
                gap: 64px;
                align-items: center;
            }
        }

        .diagnosis-benefits {
            list-style: none;
        }

        .diagnosis-benefits li {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            padding: 14px 0;
            font-size: 0.95rem;
            color: #cbd5e1;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .diagnosis-benefits li:last-child {
            border-bottom: none;
        }

        .diagnosis-benefits li svg {
            flex-shrink: 0;
            margin-top: 2px;
        }

        /* ============================================
           MAIN FORM
           ============================================ */
        .main-form-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 48px;
        }

        @media (min-width: 768px) {
            .main-form-grid {
                grid-template-columns: 1fr 1.2fr;
                gap: 64px;
                align-items: start;
            }
        }

        .main-form-trust {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .trust-badge {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px;
            background: var(--bg-alt);
            border-radius: 10px;
            border: 1px solid var(--border);
        }

        .trust-badge .badge-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(5,116,221,0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .trust-badge h4 {
            font-size: 0.9rem;
            margin-bottom: 2px;
        }

        .trust-badge p {
            font-size: 0.8rem;
            color: var(--muted);
        }

        .main-form-card {
            padding: 40px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
        }

        @media (min-width: 480px) {
            .form-row {
                grid-template-columns: 1fr 1fr;
            }
        }

        .checkbox-group {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-top: 16px;
            margin-bottom: 20px;
        }

        .checkbox-group input[type="checkbox"] {
            width: 18px;
            height: 18px;
            margin-top: 2px;
            accent-color: var(--blue);
            flex-shrink: 0;
        }

        .checkbox-group label {
            font-size: 0.82rem;
            color: var(--muted);
            line-height: 1.5;
            cursor: pointer;
        }

        .checkbox-group label a {
            color: var(--blue);
            text-decoration: underline;
        }

        /* ============================================
           FAQ
           ============================================ */
        .faq-list {
            max-width: 780px;
            margin: 0 auto;
        }

        .faq-item {
            border: 1px solid var(--border);
            border-radius: var(--radius-card);
            margin-bottom: 12px;
            overflow: hidden;
            transition: var(--transition);
        }

        .faq-item:hover {
            border-color: var(--blue);
        }

        .faq-question {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 24px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.95rem;
            color: var(--dark);
            gap: 16px;
            transition: var(--transition);
            min-height: 50px;
        }

        .faq-question:hover {
            color: var(--blue);
        }

        .faq-question:focus-visible {
            outline: 2px solid var(--blue);
            outline-offset: -2px;
        }

        .faq-chevron {
            flex-shrink: 0;
            transition: transform 0.3s ease;
        }

        .faq-item.active .faq-chevron {
            transform: rotate(180deg);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s ease;
        }

        .faq-answer-inner {
            padding: 0 24px 20px;
            font-size: 0.9rem;
            color: var(--muted);
            line-height: 1.8;
        }

        /* ============================================
           FOOTER
           ============================================ */
        .footer {
            background: var(--dark);
            padding: 64px 0 32px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 40px;
            margin-bottom: 48px;
        }

        @media (min-width: 480px) {
            .footer-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 768px) {
            .footer-grid {
                grid-template-columns: 1.5fr 1fr 1fr 1fr;
            }
        }

        .footer-col h4 {
            color: #fff;
            font-size: 0.9rem;
            margin-bottom: 20px;
        }

        .footer-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
        }

        .footer-brand img {
            height: 32px;
        }

        .footer-brand span {
            color: #fff;
            font-weight: 700;
            font-size: 1.1rem;
        }

        .footer-col p {
            font-size: 0.85rem;
            color: #64748b;
            line-height: 1.7;
        }

        .footer-col a {
            display: block;
            font-size: 0.85rem;
            color: #94a3b8;
            padding: 6px 0;
        }

        .footer-col a:hover {
            color: var(--cyan);
        }

        .footer-social {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .footer-social a {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            transition: var(--transition);
        }

        .footer-social a:hover {
            background: var(--blue);
        }

        .footer-social svg {
            width: 18px;
            height: 18px;
            fill: #94a3b8;
        }

        .footer-social a:hover svg {
            fill: #fff;
        }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.06);
            padding-top: 24px;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
        }

        .footer-bottom p {
            font-size: 0.8rem;
            color: #64748b;
        }

        /* ============================================
           FLOATING CTA (MOBILE)
           ============================================ */
        .floating-cta {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 12px 20px;
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-top: 1px solid var(--border);
            z-index: 9999;
            transition: transform 0.3s ease;
        }

        .floating-cta.hidden {
            transform: translateY(100%);
        }

        .floating-cta .btn {
            width: 100%;
        }

        @media (max-width: 1023px) {
            .floating-cta {
                display: block;
            }
        }

        /* ============================================
           UTILITIES
           ============================================ */
        .text-center { text-align: center; }
        .text-white { color: #fff !important; }
        .text-gradient {
            background: linear-gradient(135deg, var(--blue), var(--cyan));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* ============================================
           PRINT
           ============================================ */
        @media print {
            .navbar, .floating-cta, .progress-bar {
                display: none !important;
            }
            .hero {
                padding-top: 40px;
            }
            [data-reveal] {
                opacity: 1 !important;
                transform: none !important;
            }
        }
    </style>
</head>
<body>
    <!-- PROGRESS BAR -->
    <div class="progress-bar" id="progressBar" role="progressbar" aria-label="Progresso da pagina"></div>

    <!-- SECTION: NAVBAR -->
    <nav class="navbar" id="navbar" role="navigation" aria-label="Menu principal">
        <div class="container">
            <a href="#" class="navbar-logo" aria-label="Media.K - Pagina inicial">
                <img src="https://www.mediak.com.br/icon.png" alt="Media.K Logo" width="36" height="36">
                <span>Media.K</span>
            </a>

            <div class="navbar-links">
                <a href="#cases">Cases</a>
                <a href="#metodo">Metodo</a>
                <a href="#canais">Servicos</a>
                <a href="#equipe">Equipe</a>
                <a href="#faq">FAQ</a>
            </div>

            <a href="#diagnostico" class="btn btn-primary navbar-cta" aria-label="Solicitar diagnostico gratuito">Diagnostico Gratuito</a>

            <button class="hamburger" id="hamburger" aria-label="Abrir menu" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <!-- Mobile menu -->
    <div class="mobile-overlay" id="mobileOverlay"></div>
    <div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Menu mobile">
        <a href="#cases">Cases</a>
        <a href="#metodo">Metodo</a>
        <a href="#canais">Servicos</a>
